def humanize(u; d; uts):
  def u_str:
    if . > (uts | length) then
      error
    else
      uts[.].u
    end;

  def render(i):
    .
    | {i: . | floor, f: ((. - (. | floor)) | "\(.)" | .[2:4]), u: i | u_str}
    | if .f == "" then "\(.i)\(d)\(.u)" else "\(.i).\(.f)\(d)\(.u)" end;

  def h(i):
    if (. < uts[i].m) and (. >= 1)  then
      render(i)
    elif . < 1 then
      if (i == 0) then
        render(i)
      else
        . * uts[i - 1].m
        | h(i - 1)
      end
    else
      . / uts[i].m
      | h(i + 1)
    end;

  . as $v
  | (uts | map(.u == u) | indices(true)[0]) as $i
  | $v
  | if . then h($i) else . end;

